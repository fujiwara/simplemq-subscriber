FROM debian:trixie-slim
ARG TARGETARCH
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl && rm -rf /var/lib/apt/lists/*
RUN ARCH=$(case "${TARGETARCH}" in arm64) echo "arm64" ;; *) echo "x86_64" ;; esac) && \
    GOARCH=$(case "${TARGETARCH}" in arm64) echo "arm64" ;; *) echo "amd64" ;; esac) && \
    curl -fsSL "https://github.com/mesaglio/otel-front/releases/latest/download/otel-front_v0.0.1_Linux_${ARCH}.tar.gz" | tar xz -C /usr/local/bin "otel-front_linux_${GOARCH}" && \
    mv "/usr/local/bin/otel-front_linux_${GOARCH}" /usr/local/bin/otel-front
EXPOSE 8000 4317 4318
CMD ["otel-front", "--no-browser"]
